# Network: "testnet" | "mainnet". Defaults to testnet.
# (FlowVault's documented name; NEXT_PUBLIC_STACKS_NETWORK is also accepted.)
NEXT_PUBLIC_FLOWVAULT_NETWORK=testnet

# Contract principals — OPTIONAL. Default to the SDK's known deployment for the
# network (testnet = flowvault-v2 / usdcx). Set to point at a different deployment.
# NEXT_PUBLIC_FLOWVAULT_CONTRACT_ADDRESS=STD7QG84VQQ0C35SZM2EYTHZV4M8FQ0R7YNSQWPD
# NEXT_PUBLIC_FLOWVAULT_CONTRACT_NAME=flowvault-v2
# NEXT_PUBLIC_FLOWVAULT_TOKEN_CONTRACT_ADDRESS=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM
# NEXT_PUBLIC_FLOWVAULT_TOKEN_CONTRACT_NAME=usdcx

# NOTE: Susu is non-custodial. Members sign their own deposits in their own
# wallet (Leather / Xverse) via @stacks/connect. There are deliberately NO
# private keys in this app's environment — the coordinator only reads on-chain
# state, persists circle metadata, and computes the schedule (never funds/keys).

# Optional — persist circles in Upstash Redis (Vercel Marketplace -> Upstash Redis).
# Without these, circles use an in-memory store: fine for local dev, but it resets
# on restart and does NOT persist across serverless invocations in production.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
